# 🏠 Search House Frontend - Environment Variables Example
# 이 파일을 .env 로 복사한 뒤 본인의 API 키를 입력하세요.
# 복사 방법: cp .env.example .env

# --- [필수] 지도 서비스 설정 ---
# 사용할 지도 엔진을 선택하세요: 'naver' (권장) 또는 'kakao'
VITE_MAP_PROVIDER=naver

# --- [네이버 지도 설정 - 권장] ---
# 1. 네이버 클라우드 플랫폼 (https://www.ncloud.com/) 접속
# 2. Console -> AI·NAVER API -> Maps -> Mobile Dynamic Map 신청
# 3. [Client ID]를 아래에 입력
# 4. [Web 서비스 URL]에 http://localhost:5173 (또는 배포 도메인) 등록 필수!
VITE_NAVER_MAP_CLIENT_ID=your_naver_client_id_here

# --- [카카오 지도 설정] ---
# 1. 카카오 개발자 콘솔 (https://developers.kakao.com/) 접속
# 2. [JavaScript 키]를 아래에 입력
# 3. [플랫폼 -> Web -> 사이트 도메인] 등록 필수!
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# --- [백엔드 API 설정] ---
# 로컬 개발 시에는 보통 http://localhost:8000 을 사용합니다.
# 비워둘 경우 기본 배포 서버(Render 등)로 연결됩니다.
VITE_API_URL=http://localhost:8000
